# PROD_DATABASE_URL="postgresql://user:pass@host:5432/prod_db?sslmode=require"
# DEV_DATABASE_URL="postgresql://user:pass@localhost:5432/dev_db"
# SQLITE_DATABASE_URL="file:./dev.db"

# SendGrid (email reset codes)
SENDGRID_API_KEY=""
SENDGRID_FROM="no-reply@example.com"

# Twilio (SMS reset codes)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""

# Notification transport
# - "log" writes outbound notifications to the NotificationLog table only
# - "live" sends through SendGrid/Twilio and logs the result
# - "off" disables meet notifications entirely
NOTIFICATIONS_TRANSPORT="log"

# Development/testing toggles
SKIP_EMAIL_VERIFICATION="true"
SKIP_2FA_VERIFICATION="true"

# OAuth providers
